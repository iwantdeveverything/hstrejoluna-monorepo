{
  "name": "hstrejoluna-monorepo",
  "private": true,
  "scripts": {
    "build": "turbo run build --filter=portfolio --filter=maestros-del-salmon",
    "dev": "turbo run dev",
    "lint": "turbo run lint --filter=portfolio --filter=maestros-del-salmon",
    "typecheck": "turbo run typecheck --filter=portfolio --filter=maestros-del-salmon",
    "test": "turbo run test --filter=portfolio --filter=maestros-del-salmon",
    "storybook": "npm run storybook --workspace=apps/portfolio",
    "storybook:build": "npm run storybook:build --workspace=apps/portfolio",
    "storybook:build:expect-fail": "npm run storybook:build:expect-fail --workspace=apps/portfolio",
    "format": "prettier --write \"**/*.{ts,tsx,md}\""
  },
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "packageManager": "npm@10.33.0",
  "devDependencies": {
    "@sanity/client": "^7.20.0",
    "@tailwindcss/postcss": "^4.2.2",
    "lucide-react": "^1.7.0",
    "next": "^16.2.2",
    "node-fetch": "^3.3.2",
    "prettier": "latest",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "turbo": "latest",
    "typescript": "latest"
  }
}
