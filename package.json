{
  "name": "hstrejoluna-monorepo",
  "private": true,
  "scripts": {
    "build": "turbo run build --filter=portfolio",
    "dev": "turbo run dev",
    "lint": "turbo run lint --filter=portfolio",
    "typecheck": "turbo run typecheck --filter=portfolio",
    "test": "turbo run test --filter=portfolio",
    "storybook": "pnpm --filter portfolio storybook",
    "storybook:build": "pnpm --filter portfolio storybook:build",
    "storybook:build:expect-fail": "pnpm --filter portfolio storybook:build:expect-fail",
    "format": "prettier --write \"**/*.{ts,tsx,md}\""
  },
  "packageManager": "pnpm@10.4.0",
  "devDependencies": {
    "@sanity/client": "^7.20.0",
    "@tailwindcss/postcss": "^4.2.2",
    "lucide-react": "^1.7.0",
    "next": "^16.2.2",
    "node-fetch": "^3.3.2",
    "prettier": "latest",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "turbo": "latest",
    "typescript": "latest"
  }
}
